# ==============================================================================
# Qubolt — Environment Variables
# Copy this file to .env and fill in real values before starting.
# NEVER commit .env to version control.
# ==============================================================================

# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info
SERVICE_NAME=quiz-server

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_PORT=5000
# Comma-separated list of allowed CORS origins
CLIENT_URL=http://localhost:5173,https://yourdomain.com

# ── Database ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://admin:password@localhost:27017/quiz_platform?authSource=admin

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be cryptographically random (e.g., openssl rand -hex 64)
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_64
# Must be DIFFERENT from JWT_SECRET — used only for refresh tokens
JWT_REFRESH_SECRET=CHANGE_ME_different_from_jwt_secret

# ── Payment Service ───────────────────────────────────────────────────────────
PAYMENT_SERVICE_PORT=5001
PAYMENT_SERVICE_URL=http://localhost:5001
PAYMENT_PROXY_TIMEOUT_MS=8000

# ── AI Generation (OpenAI-compatible) ────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ── Payment Service — Razorpay ────────────────────────────────────────────────
# Use rzp_test_* in staging, rzp_live_* in production
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
# Webhook secret from Razorpay dashboard > Webhooks > Edit > Secret
WEBHOOK_SECRET=your_razorpay_webhook_secret

# ── Payment Service — DB (can be same as main or separate) ───────────────────
DATABASE_URL=mongodb://admin:password@localhost:27017/quiz_platform?authSource=admin

# ── Payment Service — CORS ────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173,https://yourdomain.com

# ── Payment Service — Commission (platform fee %) ─────────────────────────────
PLATFORM_FEE_PERCENT=20
ROUTE_SPLIT_ENABLED=true

# ── Feature Flags ─────────────────────────────────────────────────────────────
PAYMENTS_ENABLED=true
# Use mocked Razorpay flow in local/dev environments
MOCK_PAYMENTS_ENABLED=true
# Enable subscription expiry cron job (only on one instance in cluster)
SUBSCRIPTION_JOBS_ENABLED=false
# Enable failed job retry worker (only on one instance in cluster)
FAILED_JOB_WORKER_ENABLED=true

# ── Razorpay Subscription Plan IDs (optional — from Razorpay dashboard) ───────
# RAZORPAY_PLAN_PRO_ID=plan_xxxxxxxx
# RAZORPAY_PLAN_PREMIUM_ID=plan_xxxxxxxx

# ── Client (Vite) ─────────────────────────────────────────────────────────────
VITE_API_URL=/api
VITE_API_TIMEOUT_MS=12000
